# Supabase - Project URL and keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alpha Vantage - Stock/market data API
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Anthropic - AI/LLM API key
ANTHROPIC_API_KEY=sk-ant-...

# Resend - Transactional email service
RESEND_API_KEY=re_...

# App URL - Public-facing URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sender email address for outbound emails (must be verified in Resend)
SENDER_EMAIL=you@yourdomain.com

# Banco Central de Chile API credentials
BCCH_API_USER=your-email@example.com
BCCH_API_PASSWORD=your-password

# Bolsa de Santiago API token
BOLSA_SANTIAGO_API_TOKEN=your-token

# Upstash Redis - Rate limiting (optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# 2captcha - Automatic CAPTCHA solving for CMF cartola download (~$0.003/captcha)
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# Telegram Bot - Notifications for sync failures/successes (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Vercel Cron secret
CRON_SECRET=your-random-cron-secret

# HMAC secret for signing risk profile tokens (falls back to CRON_SECRET if not set)
HMAC_SECRET=your-random-hmac-secret

# Sentry - Error tracking (optional, disabled when DSN not set)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_...
